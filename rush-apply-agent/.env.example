# ─── RushApply Backend ────────────────────────────
BACKEND_URL=http://localhost:8080
INTERNAL_API_KEY=your_internal_api_key_here

# ─── AI Providers (priority: Claude → Groq → OpenAI → Pollinations) ───
# At least one recommended. Pollinations requires no key (free fallback).
ANTHROPIC_API_KEY=sk-ant-api03-...
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-proj-...

# ─── Browser ──────────────────────────────────────
# true = no visible window (recommended for production)
# false = show browser (useful for debugging)
HEADLESS=true

# ─── Pollinations (free fallback, no key needed) ──
POLLINATIONS_API_URL=https://text.pollinations.ai/
