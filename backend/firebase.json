{
  "functions": {
    "source":  "functions",
    "runtime": "nodejs20",
    "predeploy": [
      "npm --prefix functions install",
      "npm --prefix .. run build",
      "npm --prefix functions run build"
    ]
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/**",     "function": "api" }
    ]
  },
  "emulators": {
    "functions": { "port": 5001 },
    "hosting":   { "port": 5000 },
    "ui":        { "enabled": true }
  }
}